APP_NAME=dg-api
APP_ENV=dev
APP_PORT=8000
APP_LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dg

# Future auth providers
ENABLE_DEV_AUTH=true
JWT_ISSUER=dg-api
JWT_AUDIENCE=dg-spa
JWT_ALGORITHM=RS256
JWT_KEY_ID=dg-api-key-1
ACCESS_TOKEN_EXPIRES_MINUTES=60
# RSA keypair for signing access tokens (RS256). The public key is exposed at
# GET /api/v1/auth/public-key and GET /api/v1/auth/.well-known/jwks.json for the SPA.
# Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Then paste the PEM contents on a single line, escaping newlines as \n.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Azure
AZURE_STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=api-audit-logs
